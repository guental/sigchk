function grep() {
local line count
count=0
while read -r line; do
	case "${count}" in
		512)
			break
		;;
	esac
	if [[ "${line}" =~ \#GOGCRCSTRING ]]; then
		printf -- '%s\n' "${line}"
		break
	fi
	count=$(( count + 1 ))
done < /dev/stdin
}
function convert_hash() {
local hash hash_count hash_n hash_sum hash_cut
hash="${1%%'#GOGCRCSTRING'*}"
hash_exc=$( set_md_five_bin_exceptions "${file}" )
hash="00000000${hash:-"${hash_exc}"}"
hash="${hash,,}"
hash_count="${#hash}"
hash_count=$(( hash_count - 2 ))
hash_count="${hash:$hash_count:2}"
case "${hash_count}" in
	"")
		return 1
	;;
	00)
		return 1
	;;
	01|02|03|04|05|06|07|08|09)
		hash_n="${hash_count/#"0"}"
	;;
	*)
		hash_n="${hash_count}"
	;;
esac
hash_sum=$(( hash_n * 32 ))
hash="${hash/%"${hash_count}"}"
hash_cut="${#hash}"
hash_cut=$(( hash_cut - hash_sum ))
hash="${hash:$hash_cut:$hash_sum}"
for i in $( seq 1 $hash_n ); do
	printf -- '%s\n' "${hash:0:32}  ${file/%'.exe'}-${i}.bin"
	hash="${hash:32}"
done
}
function extract_exe() {
local hash exception
hash=$( tac -- "${1}" 2>/dev/null | cat -e | grep )
file="${1}"
case "${hash}" in
	*"00#GOGCRCSTRING"*)
		return 2
	;;
	*"#GOGCRCSTRING"*)
		convert_hash "${hash}"
	;;
	"")
		exception=$( convert_hash "${hash}" )
		case "${exception}" in
			"")
				return 3
			;;
			*)
				printf -- '%s\n' "${exception}"
			;;
		esac
	;;
	*)
		return 1
	;;
esac
}
