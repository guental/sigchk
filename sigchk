function mkdel()
{
	rm -f -- "/tmp/${0##*'/'}_${rc}.zip"
}
function mkzip() {
local line random
while read -r line; do
	unset rc
	random+="${line//[^[:alnum:]]}"
	rc="${random:0:16}"
	case "${#rc}" in
	"16")
	if ! [[ -e "/tmp/${0##*'/'}_${rc}.zip" ]]; then
		if ln -s /dev/null "/tmp/${0##*'/'}_${rc}.zip"; then
			printf -- '%s\n' "/tmp/${0##*'/'}_${rc}.zip"
			trap 'mkdel' INT TERM EXIT
			return 0
		else
			exit_code=1
			return 1
		fi
		break
	else
		unset random
	fi
	;;
	esac
done < /dev/urandom
}
function test_zip() {
	tmp_zip=$( mkzip )
	readarray -t zip_is < <( zip -F "${1}" --out "${tmp_zip}" 2>/dev/null )
	ok="Zip entry offsets do not need adjusting"
	case "${zip_is[1]}" in
		"${ok}")
			if unzip -t "${1}" &>/dev/null; then
				printf -- '%s\n' "${1}: OK"
				return 0
			else
				printf -- '%s\n' "${1}: FAILED"
				exit_code=1
				return 1
			fi
		;;
		*)
			printf -- '%s\n' "${1}: FAILED"
			exit_code=1
			return 1			
		;;
	esac
}
