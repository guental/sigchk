function set_parallel_cnum() {
local IFS line
cnum=0
while read -r line; do
	case "${line}" in
		processor*)
			cnum=$(( cnum + 1 ))
		;;
	esac
done < "/proc/cpuinfo"
case "${cnum}" in
	0|1)
		parallel_on=0
		unset cnum
		return 1
	;;
	2|3|4|5|6|7|8)
		:
	;;
	*)
		cnum=8
	;;
esac
}
function run_in_parallel() {
if parallel -j "${cnum:-"2"}" -- "${argv[@]/#/"${0} -p -- "}"; then
	exit 0
else
	exit 1
fi
}
function interrupt_exit() {
printf -- '\n'
exit 130
}
function main() {
case "${#}" in
	0)
		exit 0
	;;
esac
trap 'interrupt_exit' INT
while getopts ":p:" option; do
	case "${option}" in
		p)
			parallel_on=2
		;;
	esac
done
shift $(( OPTIND - 1 ))
case "${parallel_on}" in
	"")
		if command -v "parallel" &>/dev/null; then
			set_parallel_cnum
			parallel_on=1
		fi
	;;
esac
case "${#}" in
	1)
		parallel_on=0
	;;
esac
case "${parallel_on:-"0"}" in
	2)
		argv=( "${*}" )
	;;
	1)
		argvn="${*//[^[:punct:]]}"
		if ! [[ "${argvn}" =~ \' ]]; then
				argv=( "${@/%/"'"}" )
				argv=( "${argv[@]/#/"'"}" )
				run_in_parallel
		elif ! [[ "${argvn}" =~ \" ]]; then
				argv=( "${@/%/'"'}" )
				argv=( "${argv[@]/#/'"'}" )
				run_in_parallel			
		else
			argv=( "${@}" )
		fi
		unset argvn
	;;
	0)
		argv=( "${@}" )
	;;
esac
for file in "${argv[@]}"; do
if [[ -d "${file}" ]]; then
	continue
elif [[ -f "${file}" ]]; then
	if ! [[ -r "${file}" ]]; then
	printf -- '%s\n' "${0##*'/'}: ${file}: Permission denied" 1>&2
		exit_code=1
		continue
	fi
else
	printf -- '%s\n' "${0##*'/'}: ${file}: No such file or directory" 1>&2
	exit_code=1
	continue
fi
type="${file}"
type="${type##*'.'}"
type="${type,,}"
case ${type} in
	7z|gz|xz)
		unitest "${file}"
	;;
	zst|zstd)
		test_zstd "${file}"
	;;
	rar)
		test_rar "${file}"
	;;
	zip)
		test_zip "${file}"
	;;
	jpg|jpeg)
		test_jpeg "${file}"
	;;
	png)
		test_png "${file}"
	;;
	exe)
		test_exe "${file}"
	;;
	avi|mp4|mkv)
		test_video "${file}"
	;;
esac
done
case "${else_app}" in
	1)
		printf -- '%s\n' "${0##*'/'}: please install: ffmpeg jpeginfo pngcheck zstd" 1>&2
		exit_code=1
	;;
esac
exit "${exit_code:-"0"}"
}

main "${@//'$`\'}"
}
